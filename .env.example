# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=aerial_user
POSTGRES_PASSWORD=aerial_pass
POSTGRES_DB=aerial_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL_DAYS=7

# ─── MLflow ───────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=aerial-object-classification
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# ─── FastAPI ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
MODEL_STAGE=Production
MODEL_VERSION=v1
DRONE_ALERT_THRESHOLD=0.90
MAX_UPLOAD_SIZE_MB=10
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
RELOAD_SECRET=your-secret-here

# ─── GCS (Phase 1 ETL) ────────────────────────────────────────
GCS_BUCKET_NAME=aerial-detection-raw
GCS_RAW_PREFIX=raw/
GCS_PROCESSED_PREFIX=processed/
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcs-service-account.json

# ─── Airflow ──────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://aerial_user:aerial_pass@postgres:5432/airflow_db
AIRFLOW__CORE__FERNET_KEY=

# ─── Grafana ──────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123

# ─── Drift Detection ──────────────────────────────────────────
DRIFT_WARNING_THRESHOLD=0.3
DRIFT_CRITICAL_THRESHOLD=0.5
